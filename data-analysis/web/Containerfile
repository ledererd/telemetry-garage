# Racing Data Analysis Web Application (Podman compatible)
# Same as Dockerfile for Docker/Podman compatibility
FROM nginx:alpine

###########################################################
# These lines are needed for deployment into OpenShift
# Ensure directories are group-writable by the root group (GID 0)
RUN mkdir -p /var/cache/nginx/client_temp && \
    chmod -R 775 /var/cache/nginx && \
    chown -R root:root /var/cache/nginx && \

RUN mkdir -p /var/run/nginx && \
    chown -R root:root /var/run/nginx && \
    chmod -R 775 /var/run/nginx

# Ensure files to be served also have the correct permissions if needed
RUN chmod -R 775 /usr/share/nginx/html
###########################################################

# Copy nginx configuration
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy static web application files
COPY index.html styles.css /usr/share/nginx/html/
COPY js/ /usr/share/nginx/html/js/

# Copy entrypoint for runtime config injection
COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

# Default API URLs (overridable via environment variables at runtime)
ENV API_BASE_URL=http://localhost:8000
ENV SIMULATION_BASE_URL=http://localhost:8002

EXPOSE 80

ENTRYPOINT ["/docker-entrypoint.sh"]
